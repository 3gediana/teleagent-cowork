# Copy this file to `frontend/.env.local` and edit as needed.
# `.env.local` is git-ignored so machine-specific config stays out of the repo.
#
# Both keys below are read by `vite.config.ts` at dev-server startup
# (loadEnv); they do not affect the production build.

# Comma-separated list of public hostnames vite will accept inbound
# connections from. Required when exposing the dev server through any
# HTTP/HTTPS tunneling service (Cloudflared, ngrok, frp, 花生壳, 小米球,
# Tailscale Funnel, etc.) — vite refuses unknown hostnames by default.
#
# Leave empty for local-only development (only localhost and 127.0.0.1
# are allowed in that case).
#
# Example:
#   A3C_ALLOWED_HOSTS=abc123.example-tunnel.tld,def456.another-tunnel.tld
A3C_ALLOWED_HOSTS=

# Backend HTTP base URL the dev server should proxy /api/* to. The default
# matches the platform's default port. Override only if you run the backend
# on a different host or port.
#
# Example:
#   A3C_BACKEND_URL=http://127.0.0.1:3003
A3C_BACKEND_URL=
